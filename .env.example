# Modelo de configuração de ambiente — copie para .env e preencha
# Gere uma chave com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=troque-por-uma-chave-secreta
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (formato dj-database-url). Vazio = usa SQLite local.
# Exemplo Postgres: postgres://user:senha@localhost:5432/nome_banco
DATABASE_URL=

# CORS — origens permitidas (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Segurança HTTPS (use True em produção com HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
